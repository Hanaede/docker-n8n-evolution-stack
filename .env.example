# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
TZ=Europe/Madrid

# -----------------------------------------------------------------------------
# Published ports on the host
# -----------------------------------------------------------------------------
N8N_PORT=5678
POSTGRES_PORT=5432
REDIS_PORT=6379
EVOLUTION_PORT=8080
ADMINER_PORT=8081

# -----------------------------------------------------------------------------
# PostgreSQL / pgvector
# -----------------------------------------------------------------------------
POSTGRES_IMAGE=pgvector/pgvector:pg16
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

N8N_POSTGRES_DB=n8n
EVOLUTION_POSTGRES_DB=evolution
RAG_POSTGRES_DB=rag

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_IMAGE=redis:8-bookworm

# -----------------------------------------------------------------------------
# Adminer
# -----------------------------------------------------------------------------
ADMINER_IMAGE=adminer:4.8.1

# -----------------------------------------------------------------------------
# n8n
# Notes:
# - n8n no longer supports bootstrap admin/basic-auth via env vars in v1+.
# - The owner user is created on first access in the web UI.
# -----------------------------------------------------------------------------
N8N_IMAGE=docker.n8n.io/n8nio/n8n:stable
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=change-this-to-a-long-random-string
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_DIAGNOSTICS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false

# -----------------------------------------------------------------------------
# Evolution API
# -----------------------------------------------------------------------------
EVOLUTION_IMAGE=evoapicloud/evolution-api:latest
EVOLUTION_SERVER_URL=http://localhost:8080
AUTHENTICATION_API_KEY=change-me
EVOLUTION_AUTHENTICATION_TYPE=apikey
EVOLUTION_SESSION_PHONE_CLIENT=Evolution API
EVOLUTION_SESSION_PHONE_NAME=Chrome
EVOLUTION_DEL_INSTANCE=false
EVOLUTION_DATABASE_SAVE_DATA_INSTANCE=true
EVOLUTION_DATABASE_SAVE_DATA_NEW_MESSAGE=true
EVOLUTION_DATABASE_SAVE_MESSAGE_UPDATE=true
EVOLUTION_DATABASE_SAVE_DATA_CONTACTS=true
EVOLUTION_DATABASE_SAVE_DATA_CHATS=true
EVOLUTION_DATABASE_SAVE_DATA_LABELS=true
EVOLUTION_DATABASE_SAVE_DATA_HISTORIC=true
EVOLUTION_DATABASE_CLIENT_NAME=evolution_local
EVOLUTION_REDIS_DB=1
EVOLUTION_REDIS_PREFIX_KEY=evolution
EVOLUTION_REDIS_TTL=604800
EVOLUTION_REDIS_SAVE_INSTANCES=true
