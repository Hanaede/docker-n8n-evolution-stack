        "jsCode": "let latest = null;\ntry {\n  latest = $json.latestBuffer ? JSON.parse($json.latestBuffer) : null;\n} catch (error) {\n  latest = null;\n}\nif (!latest || latest.token !== $json.debounceToken) {\n  return [];\n}\nreturn {\n  json: {\n    ...$json,\n    chatInput: latest.text,\n    groupedMessageText: latest.text\n  }\n};"
      },
