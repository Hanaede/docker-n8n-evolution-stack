          "responseData": "ok"
        }
      },
      "id": "0b9419ab-0d5f-4560-af22-82ff315a9779",
      "name": "Evolution Incoming Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
